# 复制为 .env 后填写（不要将 .env 提交到 Git）
SECRET_KEY=change-me-in-production

# 阿里云 DashScope（视频理解、文本生成、分镜图、图生视频等）
DASHSCOPE_API_KEY=

# 二创审核准入分（0-100，默认 60）
RECREATION_REVIEW_PASS_SCORE=60

# 其他可选（见 config.py）
# SILICONFLOW_API_KEY=
# COMFYUI_URL=http://127.0.0.1:8188

# ---------- Supabase（可选）----------
# 设置 SUPABASE_JWT_SECRET 后，API 使用 Authorization: Bearer，不再使用本地 /api/auth/login
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-xxx.pooler.supabase.com:6543/postgres?sslmode=require
# SUPABASE_JWT_SECRET=
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET_USER_VIDEOS=user-videos

# ---------- 本地登录（未设置 SUPABASE_JWT_SECRET 时）----------
# DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_PASSWORD=admin123
